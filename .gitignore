# =============================================================================
# .gitignore — 白名单策略：全局拒绝，仅放行指定文件
# =============================================================================


# ── Layer 1: 全局拒绝 ─────────────────────────────────────────────────────────
*

# ── Layer 2: 放行目录遍历（否则 Git 无法深入子目录匹配白名单）──────────────
!*/

# ── Layer 3: 硬拒绝（不可逆转，即使白名单也无法覆盖）─────────────────────────
rawData/
ansisly/DATA/
文献/
绘图/
backUp/
.idea/
.vscode/
.cursor/
.trae/
.claude/
.qoder/
.agents/
.writing/
_workspace/
__pycache__/
.pytest_cache/
*.pyc
*.pkl
*.joblib
*.pth
*.h5
*.zip
.env
.env.*
*.pem
*.key
*.log

# ── Layer 4: 白名单放行（仅此以下文件纳入版本控制）──────────────────────────

# 根目录文档
!README.md
!ENVIRONMENT.md
!requirements.txt
!requirements_all.txt

# 流水线核心脚本（ansisly/汇总/script/）
!ansisly/汇总/script/01_data_preprocessing.py
!ansisly/汇总/script/02_gene_features.py
!ansisly/汇总/script/03_model_training.py
!ansisly/汇总/script/04_multi_timepoint.py
!ansisly/汇总/script/05_run_all.py
!ansisly/汇总/script/shared_utils.py
!ansisly/汇总/script/pipeline_config.json

# 因果模型脚本（031-034）及辅助模块
!ansisly/汇总/script/031_Casual_model.py
!ansisly/汇总/script/032_CausalModel.py
!ansisly/汇总/script/033_CausalModel.py
!ansisly/汇总/script/034_CausalModel.py
!ansisly/汇总/script/035_CasualModel.py
!ansisly/汇总/script/causal_egm_adapter.py
!ansisly/汇总/script/config_causal.py
!ansisly/汇总/script/deepsurv_head.py
!ansisly/汇总/script/gain_imputer.py
!ansisly/汇总/script/vae_augmentor.py
!ansisly/汇总/script/grid_search_gate_prior.py
!ansisly/汇总/script/grid_search_regularizers.py
!ansisly/汇总/script/036_CasualModel.py


# causal_meta_surv 核心包
!ansisly/汇总/script/causal_meta_surv/__init__.py
!ansisly/汇总/script/causal_meta_surv/augmentation.py
!ansisly/汇总/script/causal_meta_surv/contracts.py
!ansisly/汇总/script/causal_meta_surv/data.py
!ansisly/汇总/script/causal_meta_surv/encoders.py
!ansisly/汇总/script/causal_meta_surv/ensemble.py
!ansisly/汇总/script/causal_meta_surv/evaluation.py
!ansisly/汇总/script/causal_meta_surv/fusion.py
!ansisly/汇总/script/causal_meta_surv/heads.py
!ansisly/汇总/script/causal_meta_surv/losses.py
!ansisly/汇总/script/causal_meta_surv/meta_trainer.py
