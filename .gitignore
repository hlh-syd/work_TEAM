# =============================================================================
# .gitignore — 默认放行，按需排除
# =============================================================================

# ─── 原始数据（体积巨大，不纳入版本控制）─────────────────────────────────────
rawData/

# ─── 分析中间数据与预处理产物 ────────────────────────────────────────────────
ansisly/DATA/
ansisly/因果优先级+机器学习生存验证/data/

# ─── 分析运行结果（每次运行生成，不纳入版本控制）───────────────────────────────
ansisly/3 年总生存期风险预测/results/
ansisly/因果优先级+机器学习生存验证/results/
ansisly/汇总/results/

# ─── 文献 PDF / 图片（二进制大文件）───────────────────────────────────────────
文献/

# ─── Python 缓存 ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ─── IDE / 编辑器配置 ────────────────────────────────────────────────────────
.idea/
.vscode/
.cursor/
.trae/
.claude/
.qoder/

# ─── 日志与临时文件 ──────────────────────────────────────────────────────────
*.log
*.bak
*.bak*
*.tmp
*.swp
*.swo
*~

# ─── 环境变量与密钥（安全）────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key

# ─── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

.gitignore
